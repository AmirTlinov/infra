#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
import os
import socket
import subprocess
import sys
import tempfile
import time
from http.server import SimpleHTTPRequestHandler, ThreadingHTTPServer
from pathlib import Path
from typing import Any

SSH_READY_TIMEOUT_S = 20.0
SSH_SMOKE_IMAGE = "catthehacker/ubuntu:act-latest"


def _repo_root() -> Path:
    return Path(__file__).resolve().parents[1]


def _docker(args: list[str]) -> str:
    try:
        out = subprocess.run(["docker", *args], check=True, capture_output=True, text=True)
    except subprocess.CalledProcessError as err:
        detail = (err.stderr or err.stdout or str(err)).strip()
        raise RuntimeError(f"docker {' '.join(args)} failed: {detail}") from err
    return out.stdout.strip()


def _ensure_docker_daemon() -> None:
    try:
        _docker(["info"])
    except RuntimeError as err:
        raise RuntimeError(
            "Docker daemon is not reachable for the current user; "
            "check that Docker is running and that your user has daemon/socket access.\n"
            f"{err}"
        ) from err


def _docker_logs(container_id: str) -> str:
    proc = subprocess.run(
        ["docker", "logs", container_id],
        check=False,
        capture_output=True,
        text=True,
    )
    parts = [part.strip() for part in (proc.stdout, proc.stderr) if part and part.strip()]
    return "\n".join(parts)


def _reserve_local_port() -> int:
    with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as sock:
        sock.bind(("127.0.0.1", 0))
        sock.listen(1)
        return int(sock.getsockname()[1])


def _wait_tcp(host: str, port: int, *, timeout_s: float) -> None:
    deadline = time.time() + timeout_s
    while time.time() < deadline:
        try:
            with socket.create_connection((host, port), timeout=0.5):
                return
        except OSError:
            time.sleep(0.05)
    raise TimeoutError(f"timeout waiting for TCP {host}:{port}")


def _wait_ssh_banner(container_id: str, host: str, port: int, *, timeout_s: float) -> None:
    deadline = time.time() + timeout_s
    last_error = "sshd has not reported readiness yet"
    while time.time() < deadline:
        logs = _docker_logs(container_id)
        if "Server listening on" in logs:
            return
        try:
            with socket.create_connection((host, port), timeout=0.5) as sock:
                sock.settimeout(1.5)
                banner = sock.recv(64)
                if banner.startswith(b"SSH-"):
                    return
                last_error = f"unexpected banner prefix: {banner!r}"
        except OSError as err:
            last_error = repr(err)
            time.sleep(0.1)
    tail = logs.splitlines()[-20:]
    logs_tail = "\n".join(tail)
    raise TimeoutError(
        f"timeout waiting for SSH readiness {host}:{port}; last_error={last_error}\n{logs_tail}"
    )


def _wait_postgres_ready(container_id: str, *, timeout_s: float) -> None:
    deadline = time.time() + timeout_s
    while time.time() < deadline:
        rc = subprocess.call(
            ["docker", "exec", container_id, "pg_isready", "-U", "infrauser", "-d", "infradb"],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )
        if rc == 0:
            return
        time.sleep(0.2)
    raise TimeoutError("timeout waiting for postgres readiness")


def _start_http_server(directory: Path) -> tuple[ThreadingHTTPServer, int]:
    class QuietHandler(SimpleHTTPRequestHandler):
        def log_message(self, format: str, *args: object) -> None:  # noqa: A002
            return

    handler = lambda *args, **kwargs: QuietHandler(  # noqa: E731
        *args, directory=str(directory), **kwargs
    )
    server = ThreadingHTTPServer(("127.0.0.1", 0), handler)
    _, port = server.server_address

    import threading

    thread = threading.Thread(target=server.serve_forever, daemon=True)
    thread.start()
    _wait_tcp("127.0.0.1", int(port), timeout_s=2.0)
    return server, int(port)


def _binary_path(root: Path, profile: str) -> Path:
    build_cmd = ["cargo", "build"]
    bin_dir = root / "target" / "debug"
    if profile == "release":
        build_cmd.append("--release")
        bin_dir = root / "target" / "release"
    subprocess.run(build_cmd, cwd=str(root), check=True)
    binary = bin_dir / "infra"
    if sys.platform == "win32":
        binary = binary.with_suffix(".exe")
    if not binary.exists():
        raise RuntimeError(f"built binary missing: {binary}")
    return binary


def _cli(
    binary: Path,
    *,
    cwd: Path,
    env: dict[str, str],
    args: list[str],
    expect_exit: int = 0,
) -> dict[str, Any]:
    proc = subprocess.run(
        [str(binary), *args],
        cwd=str(cwd),
        env=env,
        capture_output=True,
        text=True,
    )
    stdout = proc.stdout.strip()
    stderr = proc.stderr.strip()
    payload: dict[str, Any] | None = None
    if stdout:
        try:
            payload = json.loads(stdout)
        except json.JSONDecodeError as err:
            raise RuntimeError(
                f"infra {' '.join(args)} returned non-JSON stdout:\n{stdout}\n\nstderr:\n{stderr}"
            ) from err
    if proc.returncode != expect_exit:
        raise RuntimeError(
            f"infra {' '.join(args)} exited rc={proc.returncode} (expected {expect_exit})\n"
            f"stdout:\n{stdout}\n\nstderr:\n{stderr}"
        )
    if payload is None or not isinstance(payload, dict):
        raise RuntimeError(f"infra {' '.join(args)} returned empty or invalid JSON payload")
    return payload


def _require(condition: bool, message: str) -> None:
    if not condition:
        raise RuntimeError(message)


def _json_arg(value: Any) -> str:
    return json.dumps(value, separators=(",", ":"))


def main() -> int:
    parser = argparse.ArgumentParser(description="Infra — docker-backed CLI smoke test.")
    parser.add_argument(
        "--load-n",
        type=int,
        default=50,
        help="Number of `infra describe status` calls for the lightweight load loop.",
    )
    parser.add_argument(
        "--profile",
        choices=("release", "debug"),
        default="release",
        help="Infra build profile to smoke; default validates the release binary path.",
    )
    args = parser.parse_args()

    root = _repo_root()

    subprocess.run(["docker", "--version"], check=True, stdout=subprocess.DEVNULL)
    _ensure_docker_daemon()
    binary = _binary_path(root, args.profile)

    pg_id = ""
    ssh_id = ""
    http_server: ThreadingHTTPServer | None = None
    pg_socket_dir = tempfile.mkdtemp(prefix="infra-smoke-pgsock-")
    try:
        ssh_port = _reserve_local_port()
        ssh_id = _docker(
            [
                "run",
                "-d",
                "--rm",
                "--network",
                "host",
                SSH_SMOKE_IMAGE,
                "bash",
                "-lc",
                "set -euo pipefail; "
                "mkdir -p /run/sshd; "
                "echo 'root:root' | chpasswd; "
                "sed -i 's/^#\\?PermitRootLogin.*/PermitRootLogin yes/' /etc/ssh/sshd_config; "
                "sed -i 's/^#\\?PasswordAuthentication.*/PasswordAuthentication yes/' /etc/ssh/sshd_config; "
                "sed -i 's/^#\\?UsePAM.*/UsePAM no/' /etc/ssh/sshd_config; "
                "sed -i 's/^#\\?PubkeyAuthentication.*/PubkeyAuthentication no/' /etc/ssh/sshd_config; "
                f"if grep -q '^#\\?Port ' /etc/ssh/sshd_config; then sed -i 's/^#\\?Port .*/Port {ssh_port}/' /etc/ssh/sshd_config; else echo 'Port {ssh_port}' >> /etc/ssh/sshd_config; fi; "
                "printf '\\nAuthenticationMethods password\\nUseDNS no\\n' >> /etc/ssh/sshd_config; "
                "/usr/sbin/sshd -D -e",
            ]
        )
        _wait_ssh_banner(ssh_id, "127.0.0.1", ssh_port, timeout_s=SSH_READY_TIMEOUT_S)

        with tempfile.TemporaryDirectory(prefix="infra-smoke-state-") as state_dir, tempfile.TemporaryDirectory(
            prefix="infra-smoke-context-"
        ) as ctx_dir, tempfile.TemporaryDirectory(prefix="infra-smoke-http-") as http_dir_raw:
            pg_id = _docker(
                [
                    "run",
                    "-d",
                    "--rm",
                    "-e",
                    "POSTGRES_PASSWORD=infrapass",
                    "-e",
                    "POSTGRES_USER=infrauser",
                    "-e",
                    "POSTGRES_DB=infradb",
                    "-v",
                    f"{pg_socket_dir}:/var/run/postgresql",
                    "postgres:16-alpine",
                ]
            )
            _wait_postgres_ready(pg_id, timeout_s=15.0)

            http_dir = Path(http_dir_raw)
            (http_dir / "index.html").write_text("hello from infra-smoke\n", encoding="utf-8")
            http_server, http_port = _start_http_server(http_dir)
            http_base_url = f"http://127.0.0.1:{http_port}"

            env = os.environ.copy()
            env["INFRA_PROFILES_DIR"] = state_dir
            env["INFRA_CONTEXT_REPO_ROOT"] = ctx_dir
            env["INFRA_TOOL_TIER"] = "expert"
            env.pop("INFRA_UNSAFE_LOCAL", None)

            describe = _cli(binary, cwd=root, env=env, args=["describe", "status"])
            _require(describe.get("state") == "ready", f"describe status failed: {describe!r}")
            _require(
                isinstance(describe.get("description_snapshot"), dict),
                f"description_snapshot missing: {describe!r}",
            )

            _cli(
                binary,
                cwd=root,
                env=env,
                args=[
                    "profile",
                    "set",
                    "--arg",
                    "name=smoke-ssh",
                    "--json",
                    _json_arg(
                        {
                            "profile": {
                                "type": "ssh",
                                "data": {
                                    "host": "127.0.0.1",
                                    "port": ssh_port,
                                    "username": "root",
                                    "host_key_policy": "accept",
                                },
                                "secrets": {"password": "root"},
                            }
                        }
                    ),
                ],
            )
            _cli(
                binary,
                cwd=root,
                env=env,
                args=[
                    "profile",
                    "set",
                    "--arg",
                    "name=smoke-api",
                    "--json",
                    _json_arg(
                        {
                            "profile": {
                                "type": "api",
                                "data": {"base_url": http_base_url},
                            }
                        }
                    ),
                ],
            )
            _cli(
                binary,
                cwd=root,
                env=env,
                args=[
                    "profile",
                    "set",
                    "--arg",
                    "name=smoke-postgres",
                    "--json",
                    _json_arg(
                        {
                            "profile": {
                                "type": "postgresql",
                                "data": {
                                    "host": pg_socket_dir,
                                    "port": 5432,
                                    "user": "infrauser",
                                    "dbname": "infradb",
                                },
                                "secrets": {"password": "infrapass"},
                            }
                        }
                    ),
                ],
            )
            _cli(
                binary,
                cwd=root,
                env=env,
                args=[
                    "project",
                    "set",
                    "--arg",
                    "name=smoke",
                    "--json",
                    _json_arg(
                        {
                            "project": {
                                "description": "docker-backed smoke fixture",
                                "default_target": "prod",
                                "targets": {
                                    "prod": {
                                        "ssh_profile": "smoke-ssh",
                                        "postgres_profile": "smoke-postgres",
                                        "api_profile": "smoke-api",
                                        "repo_root": ctx_dir,
                                        "cwd": "/srv/smoke",
                                        "api_base_url": http_base_url,
                                    }
                                },
                            }
                        }
                    ),
                ],
            )

            target = _cli(
                binary,
                cwd=root,
                env=env,
                args=["target", "resolve", "--arg", "project=smoke", "--arg", "name=prod"],
            )
            resolved = target.get("result", {}).get("resolved", {})
            _require(target.get("state") == "completed", f"target resolve failed: {target!r}")
            _require(
                resolved.get("profiles", {}).get("ssh", {}).get("name") == "smoke-ssh",
                f"resolved ssh profile missing: {target!r}",
            )
            _require(
                resolved.get("profiles", {}).get("postgres", {}).get("name") == "smoke-postgres",
                f"resolved postgres profile missing: {target!r}",
            )
            _require(
                resolved.get("profiles", {}).get("api", {}).get("name") == "smoke-api",
                f"resolved api profile missing: {target!r}",
            )
            _require(
                resolved.get("paths", {}).get("repo_root", {}).get("value") == ctx_dir,
                f"resolved repo_root missing: {target!r}",
            )

            operation = _cli(
                binary,
                cwd=root,
                env=env,
                args=[
                    "operation",
                    "observe",
                    "--arg",
                    "capability=smoke.target.baseline",
                    "--arg",
                    "project=smoke",
                    "--arg",
                    "target=prod",
                    "--arg",
                    f"api_url={http_base_url}/index.html",
                    "--arg",
                    "sql=SELECT 1",
                ],
            )
            _require(operation.get("state") == "completed", f"operation observe failed: {operation!r}")
            receipt = operation.get("receipt")
            _require(isinstance(receipt, dict), f"missing inline receipt: {operation!r}")
            operation_id = receipt.get("operation_id")
            _require(isinstance(operation_id, str) and operation_id, f"missing operation_id: {operation!r}")

            receipt_get = _cli(
                binary,
                cwd=root,
                env=env,
                args=["receipt", "get", "--arg", f"operation_id={operation_id}"],
            )
            _require(receipt_get.get("state") == "completed", f"receipt get failed: {receipt_get!r}")
            bundle = receipt_get.get("result", {}).get("receipt", {})
            _require(bundle.get("capability") == "smoke.target.baseline", f"wrong receipt capability: {bundle!r}")
            _require(isinstance(bundle.get("job_outcomes"), list), f"receipt missing job_outcomes: {bundle!r}")
            _require(isinstance(bundle.get("artifacts"), list), f"receipt missing artifacts: {bundle!r}")
            _require(isinstance(bundle.get("step_trace"), list), f"receipt missing step_trace: {bundle!r}")
            _require(
                isinstance(bundle.get("description_snapshot"), dict)
                and isinstance(bundle.get("description_snapshot", {}).get("hash"), str),
                f"receipt missing description snapshot: {bundle!r}",
            )

            started = time.time()
            for _ in range(args.load_n):
                payload = _cli(binary, cwd=root, env=env, args=["describe", "status"])
                _require(payload.get("state") == "ready", f"load loop failed: {payload!r}")
            load_duration = time.time() - started

            print(
                f"OK: smoke[{args.profile}] (target resolve + operation/receipt over api/postgres/ssh) "
                f"+ describe status x{args.load_n} in {load_duration:.1f}s"
            )
            return 0
    finally:
        if http_server is not None:
            http_server.shutdown()
            http_server.server_close()
        if pg_id:
            subprocess.run(["docker", "rm", "-f", pg_id], check=False, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        if ssh_id:
            subprocess.run(["docker", "rm", "-f", ssh_id], check=False, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        subprocess.run(["rm", "-rf", pg_socket_dir], check=False, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)


if __name__ == "__main__":
    try:
        raise SystemExit(main())
    except KeyboardInterrupt:
        print("ERROR: smoke interrupted by user", file=sys.stderr)
        raise SystemExit(130)
